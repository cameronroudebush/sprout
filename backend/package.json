    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.77.6",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",

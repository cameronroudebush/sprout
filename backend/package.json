    "@types/express": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.14.202",
    "@types/node": "^25.0.10",
    "@types/nodemon": "^3.1.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/sharp": "^0.32.0",
    "@types/source-map-support": "^0.5.10",
    "@yao-pkg/pkg": "^6.8.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "cross-var": "^1.1.0",
    "git-describe": "^4.1.1",
    "jest": "^30.4.2",
    "node-loader": "^2.1.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.6.2",
    "typescript": "^6.0.2",
    "webpack-node-externals": "^3.0.0"
  },
  "overrides": {
    "google-auth-library": "^9.14.2"
  },
  "scripts": {
    "start": "nest start --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:watch:cov": "jest --watchAll --coverage",
    "test:cov": "jest --coverage",
    "build": "cross-env NODE_ENV=prod nest build && pkg package.json",
    "migrate": "cross-var typeorm-ts-node-commonjs migration:generate -d ./src/scripts/generate.migration.ts ./src/database/migration/sqlite/$npm_config_name",
    "export:api:spec": "nest start -- generate.api-spec ../docs/assets/openapi-spec.json",
    "db:reset:dev:passwords": "node -e \"const db = require('better-sqlite3')('sprout.sqlite'); db.prepare('UPDATE user SET password = ?').run('$2b$10$/9Ebit1ZTqZSGOhKQ047De24nouDhIXnKtmwpv6P85U7yBHsGsQHG'); db.close();\""
  },
  "pkg": {
    "targets": [
      "latest"
    ],
    "assets": [
      "dist/**/*",
      "node_modules/axios/**/*",
      "node_modules/plaid/node_modules/axios/**/*",
      "node_modules/bcrypt/prebuilds/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/sharp-win32-x64/**/*",
      "node_modules/@img/sharp-linuxmusl-x64/**/*",
      "node_modules/@img/sharp-libvips-linuxmusl-x64/**/*",
      "node_modules/ansis/**/*",
      "node_modules/firebase-admin/**/*",
      "node_modules/google-auth-library/**/*",
      "node_modules/@nestjs-modules/mailer/dist/adapters/**/*"
    ]
  }
}

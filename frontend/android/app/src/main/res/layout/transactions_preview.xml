<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_rounded"
    android:padding="16dp">

    <RelativeLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/widget_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/widget_logo"
            android:text="Recent Transactions"
            android:textColor="@color/sprout_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:alpha="0.7"
            android:text="Jan 01, 1:00 PM"
            android:textColor="@color/sprout_text_secondary"
            android:textSize="10sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/widget_transactions_list_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_header"
        android:orientation="vertical">

        <include layout="@layout/transaction_item_preview" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"/>

        <include layout="@layout/transaction_item_preview" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"/>

        <include layout="@layout/transaction_item_preview" />

    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_header"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="@string/widget_no_data"
        android:textColor="@color/sprout_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />
</RelativeLayout>
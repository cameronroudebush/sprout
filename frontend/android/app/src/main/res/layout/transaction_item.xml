<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/item_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/category_chip_bg"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@color/sprout_text_secondary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:text="Dining" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_toEndOf="@id/item_category"
        android:layout_toStartOf="@id/item_amount"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_merchant_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/sprout_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Starbucks" />

        <TextView
            android:id="@+id/item_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/sprout_text_secondary"
            android:textSize="10sp"
            android:text="Today" />
    </LinearLayout>

    <TextView
        android:id="@+id/item_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:textColor="@android:color/holo_red_light"
        android:textSize="14sp"
        android:textStyle="bold"
        android:text="-$5.42" />

</RelativeLayout>
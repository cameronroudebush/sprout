{
  "private": true,
  "scripts": {
    "install:all": "npm i && npm i --prefix ./backend",
    "build:docker": "ts-node --project ./scripts/tsconfig.json ./scripts/build.docker.ts",
    "screenshot": "ts-node --project ./scripts/tsconfig.json ./scripts/release.screenshots.ts",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "changelog:generate:md": "auto-changelog --template ./docs/changelog-templates/markdown.hbs",
    "changelog:generate:android": "auto-changelog --template ./docs/changelog-templates/android.hbs",
    "docs:serve": "docker run --rm -it -p 8000:8000 --entrypoint=/bin/sh -v \"%cd%\":/docs squidfunk/mkdocs-material -c \"mkdocs serve --livereload --dev-addr 0.0.0.0:8000\"",
    "api:generate:dart": "docker run --rm  -v %cd%:/local --entrypoint=/bin/sh -w /local openapitools/openapi-generator-cli -c \"openapi-generator-cli generate -i /local/docs/assets/openapi-spec.json -g dart -o /local/frontend/api --global-property apiDocs=false,modelDocs=false,apiTests=false,modelTests=false && rm -rf /local/frontend/lib/api && mkdir -p /local/frontend/lib/api && mv /local/frontend/api/lib/* /local/frontend/lib/api/ && rm -rf /local/frontend/api \"",
    "adb:reverse": "adb reverse tcp:8001 tcp:8001",
    "adb:attach:logcat": "adb logcat | Select-String -Pattern \"flutter\", \"sprout\""
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.6.0",
    "auto-changelog": "^2.5.0",
    "chrome-remote-interface": "^0.34.0",
    "git-describe": "^4.1.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "auto-changelog": {
    "template": "./docs/changelog-template.hbs",
    "package": true,
    "commitLimit": false,
    "hideEmptyReleases": true,
    "sortCommits": "date-desc",
    "unreleased": true,
    "replaceText": {
      "([bB]reaking [cC]hange:)": "Breaking Change:",
      "([bB]reaking:)": "Breaking:",
      "(^[fF]eat:)": "",
      "(^[fF]eat\\()": "(",
      "(^[fF]ix:)": "",
      "(^[fF]ix\\()": "(",
      "(^[cC]hore:)": "",
      "(^[cC]hore\\()": "(",
      "(^[dD]ocs:)": "",
      "(^[dD]ocs\\()": "(",
      "(^[rR]efactor:)": "",
      "(^[rR]efactor\\()": "(",
      "(^[tT]est:)": "",
      "(^[tT]est\\()": "(",
      "(^[sS]tyle:)": "",
      "(^[sS]tyle\\()": "(",
      "(^[pP]erf:)": "",
      "(^[pP]erf\\()": "("
    }
  }
}
